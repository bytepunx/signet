#!/bin/sh
# Runs the same format/lint checks as CI's Lint job before allowing a commit.
# Installed via `make install-hooks`. Skip once with `git commit --no-verify`.
set -e

cd "$(git rev-parse --show-toplevel)"

unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
	echo "gofmt: the following files are not formatted:"
	echo "$unformatted" | sed 's/^/  /'
	echo "Fix with: gofmt -w <file>..."
	exit 1
fi

if ! command -v golangci-lint >/dev/null 2>&1; then
	echo "golangci-lint not found on PATH."
	echo "Install the version this repo's .golangci.yml targets (v1, not v2):"
	echo "  go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.64.8"
	exit 1
fi

golangci-lint run ./...
